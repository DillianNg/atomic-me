# ============================================================
# App
# ============================================================
NODE_ENV=development
PORT=3001

# ============================================================
# Database (Postgres + pgvector)
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/atomic_me
DIRECT_URL=postgresql://user:password@localhost:5432/atomic_me

# ============================================================
# Auth (Clerk)
# ============================================================
CLERK_SECRET_KEY=sk_test_xxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_WEBHOOK_SECRET=whsec_xxxx
# Issuer cua JWT Clerk: lay tu Clerk Dashboard > API Keys (Frontend API URL).
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev

# ============================================================
# Storage (Cloudflare R2)
# ============================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=atomic-me-assets

# ============================================================
# Queue (Redis / BullMQ)
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# AI
# ============================================================
ANTHROPIC_API_KEY=sk-ant-xxxx
VOYAGE_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ============================================================
# Frontend (prefix VITE_ cho Vite expose)
# ============================================================
VITE_API_URL=http://localhost:3001
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
VITE_POSTHOG_KEY=
