# @atomic-me/web - bien moi truong (Vite chi expose bien co prefix VITE_).
# Copy file nay thanh .env.local va dien gia tri that.

# Publishable key cua Clerk (Dashboard > API Keys). An toan de lo o client.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxx

# Base URL cua backend API (@atomic-me/api).
VITE_API_BASE_URL=http://localhost:3001
