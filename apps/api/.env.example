# ============================================================
# @atomic-me/api - bien moi truong (backend)
# ============================================================
# Luu y: script `pnpm dev` cua api load file .env o ROOT repo
# (`--env-file=../../.env`), khong phai file nay. File nay la tham chieu
# liet ke day du bien ma API can; copy gia tri tuong ung vao .env root.

# --- App ---
NODE_ENV=development
PORT=3001
API_HOST=0.0.0.0
LOG_LEVEL=info

# --- Database (Postgres + pgvector) ---
DATABASE_URL=postgresql://user:password@localhost:5432/atomic_me

# --- Auth (Clerk) ---
# Lay tu Clerk Dashboard > API Keys.
CLERK_SECRET_KEY=sk_test_xxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxx
# Issuer (iss claim) cua JWT Clerk, = Frontend API URL trong Dashboard.
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev
# Signing secret cua webhook endpoint (Dashboard > Webhooks > Signing Secret).
CLERK_WEBHOOK_SECRET=whsec_xxxx
